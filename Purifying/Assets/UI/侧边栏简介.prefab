  m_Text: "\u9AD8\u5BC6\u5EA6\u6C89\u6DC0\u6C60\u662F\u4E00\u79CD\n\u9AD8\u6548\u6C34\u5904\u7406\u8BBE\u65BD\uFF0C\u7ED3\n\u5408\u5316\u5B66\u6DF7\u51DD\u3001\u7D6E\u51DD\u4E0E\u659C\u677F\u6C89\u6DC0\u6280\n\u672F\uFF0C\u901A\u8FC7\u6295\u52A0\u6DF7\u51DD\u5242\u3001\u52A9\u51DD\u5242\u53CA\n\u6C61\u6CE5\u56DE\u6D41\u7CFB\u7EDF\uFF0C\u5FEB\u901F\u5F62\u6210\u81F4\u5BC6\u7D6E\n\u4F53\u3002\u5176\u6838\u5FC3\u4F18\u52BF\u5728\u4E8E\u5904\u7406\u8D1F\u8377\u9AD8\n\u6C89\u964D\u901F\u5EA6\u5FEB\u3001\u5360\u5730\u9762\u79EF\u5C0F\uFF0C\u51FA\u6C34\n\u60AC\u6D6E\u7269\u6D53\u5EA6\u53EF\u964D\u81F310mg/L\u4EE5\n\u4E0B\u3002"
