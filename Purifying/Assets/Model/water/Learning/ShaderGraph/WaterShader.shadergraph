{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "5452cb682f2947af8fdeeed44c1c2090",
    "m_Title": "sceneColor",
    "m_Content": "sceneColor值是在此着色器执行之前（还未渲染出水体），已经在我们的帧缓冲中存在的颜色，\n所以这样我们就可以做到针对水下的模型以及影子做扰动，而不影响水上部分，因为水上部分是新渲染的\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -466.0,
        "y": -2023.0,
        "width": 200.0,
