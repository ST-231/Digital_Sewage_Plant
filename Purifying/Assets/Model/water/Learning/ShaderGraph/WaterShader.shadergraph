{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "1c409c10285a4ea093111fc5d12d9f0a",
    "m_Title": "depth",
    "m_Content": "SceneDepth节点，可以取得当前屏幕坐标下像素点的深度。即当前屏幕坐标下，包含本物体在内，屏幕上的物体和相机裁剪平面的距离。这个值包含半透明物体。\r\n\r\nScreenPosition节点，得到四个值，xyzw，其中w，同样是深度。即当前屏幕坐标下，包含本物体在内，屏幕上的物体和相机裁剪平面的距离。这个值不包含半透明物体。\n\n所以它们相减就能得到相交边缘。因为这个点有半透明物体，它的背后有不透明物体。如果半透明物体和不透明物体重合，则差值为0，如果不重合，则差值越大，半透明物体的表面距离不透明物体就越远。",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2942.0,
        "y": -82.0,
        "width": 423.0,
        "height": 300.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

