    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u7D2B\u5916\u7EBF\u6D88\u6BD2\u6C60\u662F\u6C61\u6C34\u5904\u7406\u672B\u7AEF\u7684\u5173\u952E\u6D88\u6BD2\u5355\u5143\uFF0C\u901A\u8FC7\u7D2B\u5916\u5149\uFF08UV-C\u6CE2\u6BB5\uFF0C\u6CE2\u957F200-275
    nm\uFF09\u7834\u574F\u5FAE\u751F\u7269DNA/RNA\u7ED3\u6784\uFF0C\u5B9E\u73B0\u975E\u5316\u5B66\u3001\u65E0\u6B8B\u7559\u7684\u75C5\u539F\u4F53\u706D\u6D3B\uFF0C\u5E7F\u6CDB\u7528\u4E8E\u5E02\u653F\u6C61\u6C34\u3001\u5DE5\u4E1A\u5E9F\u6C34\u53CA\u56DE\u7528\u6C34\u6D88\u6BD2\uFF0C\u5C24\u5176\u9002\u7528\u4E8E\u5BF9\u5316\u5B66\u6D88\u6BD2\u5242\u654F\u611F\u7684\u573A\u5408\uFF08\u5982\u751F\u6001\u654F\u611F\u6C34\u57DF\uFF09\u3002\n\n\u6838\u5FC3\u7ED3\u6784\u4E0E\u5DE5\u4F5C\u539F\u7406\n\n\u7D2B\u5916\u7EBF\u706F\u7BA1\u7EC4\uFF1A\n\n\u9AD8\u538B\u6216\u4F4E\u538B\u6C5E\u706F\u53D1\u5C04UV-C\u5149\uFF08253.7
    nm\u4E3A\u4E3B\uFF09\uFF0C\u76F4\u63A5\u7A7F\u900F\u5FAE\u751F\u7269\u7EC6\u80DE\u819C\u3002\n\u706F\u7BA1\u7C7B\u578B\uFF1A\u4F4E\u538B\u9AD8\u5F3A\u706F\uFF08\u5927\u6D41\u91CF\uFF09\u3001\u4E2D\u538B\u706F\uFF08\u5E7F\u8C31\u6740\u83CC\uFF09\u3002\n\n\u77F3\u82F1\u5957\u7BA1\uFF1A\u4FDD\u62A4\u706F\u7BA1\u514D\u53D7\u6C61\u6C34\u8150\u8680\uFF0C\u786E\u4FDD\u7D2B\u5916\u5149\u900F\u5C04\u7387\u3002\n\n\u53CD\u5E94\u5668\u8BBE\u8BA1\uFF1A\n\n\u660E\u6E20\u5F0F\uFF1A\u5F00\u653E\u6E20\u9053\u5185\u5E73\u884C\u6392\u5E03\u706F\u7EC4\uFF0C\u9002\u7528\u4E8E\u5927\u6D41\u91CF\u6C61\u6C34\uFF08\u5982\u5E02\u653F\u6C61\u6C34\u5382\uFF09\u3002\n\n\u5C01\u95ED\u5F0F\uFF1A\u538B\u529B\u7BA1\u9053\u5185\u7F6E\u706F\u7BA1\uFF0C\u9002\u7528\u4E8E\u5C0F\u6D41\u91CF\u6216\u56DE\u7528\u6C34\u7CFB\u7EDF\u3002\n\n\u81EA\u52A8\u6E05\u6D17\u7CFB\u7EDF\uFF1A\u673A\u68B0\u522E\u64E6\u6216\u5316\u5B66\u6E05\u6D17\uFF0C\u9632\u6B62\u77F3\u82F1\u5957\u7BA1\u7ED3\u57A2\u5F71\u54CD\u900F\u5149\u7387\u3002"
