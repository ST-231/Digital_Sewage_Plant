    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u52A0\u836F\u7BB1\u662F\u6C34\u5904\u7406\u7CFB\u7EDF\u4E2D\u7684\u5173\u952E\u836F\u5242\u5B58\u50A8\u4E0E\u6295\u52A0\u88C5\u7F6E\uFF0C\u7528\u4E8E\u7CBE\u786E\u63A7\u5236\u6DF7\u51DD\u5242\u3001\u7D6E\u51DD\u5242\u3001\u6D88\u6BD2\u5242\u7B49\u5316\u5B66\u836F\u5242\u7684\u50A8\u5B58\u3001\u7A00\u91CA\u4E0E\u6295\u52A0\u91CF\uFF0C\u5176\u8FD0\u884C\u53EF\u9760\u6027\u76F4\u63A5\u5F71\u54CD\u6C34\u8D28\u5904\u7406\u6548\u679C\u4E0E\u836F\u5242\u6210\u672C\u3002\n\n\u6838\u5FC3\u529F\u80FD\n\n\u836F\u5242\u50A8\u5B58\u4E0E\u7F13\u51B2\uFF1A\n\u5B89\u5168\u5BB9\u7EB3\u6DB2\u6001\u6216\u7C89\u72B6\u836F\u5242\uFF08\u5982PAC\u3001PAM\u3001\u6B21\u6C2F\u9178\u94A0\uFF09\uFF0C\u7F13\u51B2\u5916\u90E8\u4F9B\u836F\u538B\u529B\u6CE2\u52A8\uFF0C\u4FDD\u969C\u8FDE\u7EED\u6295\u52A0\u3002\n\n\u7CBE\u786E\u8BA1\u91CF\u6295\u52A0\uFF1A\n\u901A\u8FC7\u8BA1\u91CF\u6CF5\u6216\u7535\u78C1\u9600\u5B9E\u73B0\u836F\u5242\u6295\u52A0\u91CF\u8C03\u8282\uFF08\u7CBE\u5EA6\xB13%\uFF09\uFF0C\u9002\u914D\u4E0D\u540C\u6C34\u8D28\u9700\u6C42\uFF08\u5982\u6D4A\u5EA65-100
    NTU\uFF09\u3002\n\n\u836F\u5242\u6DF7\u5408\u4E0E\u7A00\u91CA\uFF1A\n\u5185\u7F6E\u6405\u62CC\u5668\uFF08\u8F6C\u901F20-60
    rpm\uFF09\u6216\u7A00\u91CA\u6C34\u6BD4\u4F8B\u8C03\u8282\u88C5\u7F6E\uFF08\u7A00\u91CA\u6BD41:5~1:20\uFF09\uFF0C\u786E\u4FDD\u836F\u5242\u5747\u5300\u5206\u6563\u3002\n\n\u9632\u8150\u4E0E\u5B89\u5168\u9632\u62A4\uFF1A\n\u8010\u9178\u78B1\u6750\u8D28\uFF08\u5982PE\u3001PP\u3001\u73BB\u7483\u94A2\uFF09\u4E0E\u6CC4\u6F0F\u62A5\u8B66\u7CFB\u7EDF\uFF0C\u907F\u514D\u836F\u5242\u8150\u8680\u6216\u6EA2\u6D41\u4E8B\u6545\u3002"
